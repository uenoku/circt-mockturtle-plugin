@LIT_SITE_CFG_IN_HEADER@

config.circt_experiment_src_root = "@CIRCT_EXPERIMENT_SOURCE_DIR@"
config.circt_experiment_obj_root = "@CIRCT_EXPERIMENT_BINARY_DIR@"
config.circt_experiment_tools_dir = "@LLVM_RUNTIME_OUTPUT_INTDIR@"
config.circt_experiment_plugin = "@LLVM_LIBRARY_OUTPUT_INTDIR@/CIRCTMockturtlePlugin@SHLIBEXT@"
config.circt_experiment_has_plugin = @CIRCT_EXPERIMENT_HAS_PLUGIN@
config.circt_tools_dir = lit_config.substitute("@CIRCT_TOOLS_DIR@")
config.llvm_tools_dir = lit_config.substitute("@LLVM_TOOLS_DIR@")
config.llvm_shlib_ext = "@SHLIBEXT@"
config.circt_fraig_scripts_dir = "@CIRCT_EXPERIMENT_SOURCE_DIR@/circt-synth-formal-exp/scripts"

import lit.llvm
lit.llvm.initialize(lit_config, config)

lit_config.load_config(config, "@CMAKE_CURRENT_SOURCE_DIR@/lit.cfg.py")
