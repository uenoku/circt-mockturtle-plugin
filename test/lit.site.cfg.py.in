@LIT_SITE_CFG_IN_HEADER@

config.circt_mockturtle_src_root = "@CIRCT_MOCKTURTLE_SOURCE_DIR@"
config.circt_mockturtle_obj_root = "@CIRCT_MOCKTURTLE_BINARY_DIR@"
config.circt_mockturtle_tools_dir = "@LLVM_RUNTIME_OUTPUT_INTDIR@"
config.circt_mockturtle_plugin = "@LLVM_LIBRARY_OUTPUT_INTDIR@/CIRCTMockturtlePlugin@SHLIBEXT@"
config.circt_mockturtle_has_plugin = @CIRCT_MOCKTURTLE_HAS_PLUGIN@
config.circt_tools_dir = lit_config.substitute("@CIRCT_TOOLS_DIR@")
config.llvm_tools_dir = lit_config.substitute("@LLVM_TOOLS_DIR@")
config.llvm_shlib_ext = "@SHLIBEXT@"

import lit.llvm
lit.llvm.initialize(lit_config, config)

lit_config.load_config(config, "@CMAKE_CURRENT_SOURCE_DIR@/lit.cfg.py")
