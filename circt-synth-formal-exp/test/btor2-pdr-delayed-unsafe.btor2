; RUN: not circt-fraig-lec --btor2-pdr-depth=4 %s 2>&1 | FileCheck %s --check-prefix=BMC
; RUN: not circt-fraig-lec --btor2-pdr-depth=4 --btor2-pdr-precheck-depth=1 %s 2>&1 | FileCheck %s --check-prefix=PDR
; RUN: circt-fraig-lec --input-format=btor2 --btor2-bound=1 --emit-imported %s | FileCheck %s --check-prefix=IMPORT

1 sort bitvec 1
2 zero 1
3 one 1
4 state 1 x
5 state 1 y
6 init 1 4 2
7 init 1 5 2
8 next 1 4 3
9 next 1 5 4
10 bad 5

; BMC: pdr: counterexample found by BMC at depth 2
; BMC: pdr: counterexample trace:
; BMC: pdr:   state 0: x=0 y=0
; BMC: pdr:   state 1: x=1 y=0
; BMC: pdr:   state 2: x=1 y=1

; PDR: pdr: counterexample found
; PDR: pdr: counterexample trace:
; PDR: pdr:   state 0: x=1 y=0
; PDR: pdr:   state 1: x=1 y=1

; IMPORT: fraig_lec.state_names = ["x", "y"]
