; RUN: not circt-fraig-lec --btor2-pdr-depth=4 %s 2>&1 | FileCheck %s
; RUN: not circt-fraig-lec --btor2-pdr-depth=4 --btor2-pdr-precheck-depth=1 %s 2>&1 | FileCheck %s --check-prefix=PDR

1 sort bitvec 2
2 sort bitvec 1
3 zero 1
4 const 1 01
5 const 1 10
6 state 1 s
7 init 1 6 3
8 add 1 6 4
9 next 1 6 8
10 eq 2 6 5
11 bad 10

; CHECK: pdr: counterexample found by BMC at depth 2
; CHECK: pdr: counterexample trace:
; CHECK: pdr:   state 0: s=0b00
; CHECK: pdr:   state 1: s=0b01
; CHECK: pdr:   state 2: s=0b10

; PDR: pdr: counterexample found
; PDR: pdr: counterexample trace:
; PDR: pdr:   state 0: s=0b01
; PDR: pdr:   state 1: s=0b10
