diff --git a/unittests/Support/SATSolverTest.cpp b/unittests/Support/SATSolverTest.cpp
index 25e72d6f8..894d8710c 100644
--- a/unittests/Support/SATSolverTest.cpp
+++ b/unittests/Support/SATSolverTest.cpp
@@ -198,3 +198,17 @@ TEST(SatSolverTest, CadicalConflictLimitCanBeConfigured) {
   solver->setConflictLimit(-1);
   EXPECT_EQ(IncrementalSATSolver::kUNSAT, solver->solve());
 }
+
+TEST(SatSolverTest, CadicalReportsFailedAssumptions) {
+  auto solver = createCadicalSATSolver();
+  if (!solver)
+    GTEST_SKIP() << "CaDiCaL is not available in this build.";
+
+  solver->reserveVars(3);
+  solver->addClause({-1, -2});
+
+  EXPECT_TRUE(solver->hasFailedAssumptions());
+  EXPECT_EQ(IncrementalSATSolver::kUNSAT, solver->solve({1, 2, 3}));
+  EXPECT_TRUE(solver->failedAssumption(1));
+  EXPECT_TRUE(solver->failedAssumption(2));
+}
